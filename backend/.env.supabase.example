# Supabase DB profile
# Runtime can use pooler; Alembic prefers direct
DATABASE_URL=postgresql://postgres.<user>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
ALEMBIC_DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_SSL_MODE=require

# Supabase Storage creds (service role key required for uploads)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<service-role-key>
SUPABASE_STORAGE_VEHICLE_BUCKET=Photos
SUPABASE_STORAGE_KYC_BUCKET=kyc-documents

# VPS NIC extraction (CD-51)
VPS_URL=http://<vps-ip>:8001
VPS_SECRET=<shared-internal-secret>
KYC_VPS_TIMEOUT_SECONDS=60
KYC_VPS_MAX_RETRIES=1

# Required by app settings (fill from your current .env)
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change-me
ENCRYPTION_KEY=change-me
GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me
GOOGLE_CLOUD_PROJECT=change-me
DOCUMENT_AI_PROCESSOR_ID=change-me
GOOGLE_APPLICATION_CREDENTIALS_PATH=C:\path\to\service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GEMINI_API_KEY=change-me
PAYHERE_MERCHANT_ID=change-me
PAYHERE_MERCHANT_SECRET=change-me
PAYHERE_SANDBOX=true
PAYHERE_MAX_PAYMENT_AMOUNT_LKR=100000000.00
ANTHROPIC_API_KEY=change-me
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=change-me
ADMIN_EMAILS=admin@example.com
