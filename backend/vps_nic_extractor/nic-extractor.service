[Unit]
Description=ClearDrive NIC Extractor API
After=network.target ollama.service
Requires=ollama.service

[Service]
Type=simple
User=ollama
WorkingDirectory=/home/ollama/nic-extractor
Environment="PATH=/home/ollama/nic-extractor/venv/bin"
EnvironmentFile=/home/ollama/nic-extractor/.env
ExecStart=/home/ollama/nic-extractor/venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
