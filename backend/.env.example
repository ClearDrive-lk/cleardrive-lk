# backend/.env.example

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cleardrive  # pragma: allowlist secret
DATABASE_SSL_MODE=disable  # require in production

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=JMpBUyOEoJMkZ7U3qAAgdqCCkSVlOFsVxZgG3O7ztYU
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Encryption
ENCRYPTION_KEY=Md4x_bm8pqSahfpK1NbH8J6VeEQz3ksm6Tq5wSiC-pU=

# Google OAuth
GOOGLE_CLIENT_ID=1046089482609-juac7fr382h9s5s22ol9uoaol8umk7eu.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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


# PayHere
PAYHERE_MERCHANT_ID=your-merchant-id
PAYHERE_MERCHANT_SECRET=your-merchant-secret
PAYHERE_SANDBOX=true
PAYHERE_MAX_PAYMENT_AMOUNT_LKR=100000000.00

# Claude API
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_STORAGE_VEHICLE_BUCKET=Photos
SUPABASE_STORAGE_KYC_BUCKET=kyc-documents

# VPS NIC extraction (CD-51)
VPS_URL=http://your-vps-ip:8001
VPS_SECRET=replace-with-strong-random-secret
KYC_VPS_TIMEOUT_SECONDS=60
KYC_VPS_MAX_RETRIES=1

# Gazette extraction (CD-24)
GOOGLE_CLOUD_PROJECT=your-google-cloud-project
DOCUMENT_AI_PROCESSOR_ID=your-document-ai-processor-id
# Use one of these auth options for Document AI:
GOOGLE_APPLICATION_CREDENTIALS_PATH=C:\path\to\service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GEMINI_API_KEY=your-gemini-api-key
MAX_GAZETTE_SIZE_MB=50

# Email (SMTP)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=re_your_resend_api_key
SMTP_TIMEOUT_SECONDS=10
# Optional fallback if SMTP is blocked on your host (recommended in production)
RESEND_API_KEY=re_your_resend_api_key
# Optional explicit sender for Resend API (must be verified in Resend)
# RESEND_FROM_EMAIL=onboarding@resend.dev

# Sentry
SENTRY_DSN=https://your-sentry-dsn

# Admin
ADMIN_EMAILS=malith@driveclear.lk,lehan@cleardrive.lk, tharin@cleardrive.lk, pavara@cleardrive.lk, parindra@cleardrive.lk, kalidu@cleardrive.lk

# Security
CLOUDFLARE_API_KEY=your-cf-api-key
SECURITY_EVENT_RETENTION_DAYS=30
MAX_FAILED_AUTH_ATTEMPTS=5

# Environment
ENVIRONMENT=development

# CORS / Hosts (Production)
BACKEND_CORS_ORIGINS=["http://localhost:3000","https://cleardrive.lk","https://www.cleardrive.lk"]
BACKEND_CORS_ORIGIN_REGEX=^https://.*\.vercel\.app$
BACKEND_ALLOWED_HOSTS=["localhost","127.0.0.1","api.cleardrive.lk","*.cleardrive.lk"]
