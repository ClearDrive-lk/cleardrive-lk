# Required by app settings (fill from your current .env)
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change-me
ENCRYPTION_KEY=change-me
GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me
PAYHERE_MERCHANT_ID=change-me
PAYHERE_MERCHANT_SECRET=change-me
ANTHROPIC_API_KEY=change-me
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<service-role-key>
SUPABASE_STORAGE_VEHICLE_BUCKET=Photos
SUPABASE_STORAGE_KYC_BUCKET=kyc-documents

# VPS NIC extraction (CD-51)
VPS_URL=http://<vps-ip>:8001
VPS_SECRET=<shared-internal-secret>
KYC_VPS_TIMEOUT_SECONDS=60
KYC_VPS_MAX_RETRIES=1
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=change-me
ADMIN_EMAILS=admin@example.com
